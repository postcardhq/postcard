# Google Gemini API Key (Required for live mode)
# Get your key at: https://aistudio.google.com/api-keys
GOOGLE_GENERATIVE_AI_API_KEY=

# Fake Pipeline Toggle
# Set to 'true' to use mock data for testing (no API keys required)
# Set to 'false' to use the live forensic pipeline (requires Gemini key)
NEXT_PUBLIC_FAKE_PIPELINE=true

# Optional: Specialized Social Media Clients
# Reddit API (Script app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# X/Twitter API (v2)
TWITTER_BEARER_TOKEN=

# Meta/Instagram API (Required for high-fidelity Instagram results)
INSTAGRAM_ACCESS_TOKEN=

# TikTok API (Optional, uses oEmbed)
TIKTOK_ACCESS_TOKEN=
